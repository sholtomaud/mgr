<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mgr.monitor</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/mgr</string>
        <string>monitor</string>
        <string>--start</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>~/Library/Logs/mgr/monitor.log</string>
    <key>StandardErrorPath</key>
    <string>~/Library/Logs/mgr/monitor.err</string>
</dict>
</plist>
