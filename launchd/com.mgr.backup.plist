<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.mgr.backup</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/mgr</string>
        <string>backup</string>
    </array>
    <!-- Run daily at 02:00 -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>~/Library/Logs/mgr/backup.log</string>
    <key>StandardErrorPath</key>
    <string>~/Library/Logs/mgr/backup.err</string>
</dict>
</plist>
